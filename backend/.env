# ─── Puerto del servidor ───────────────────────────────
PORT=3000

# ─── API Key secreta (cámbiala por una clave segura) ──
API_KEY_SECRET=MI_APK_SECRETO_SUPER_SEGURO_2026

# ─── URL del frontend (para CORS) ─────────────────────
# En local: http://localhost:3000 — En producción: URL de Vercel
FRONTEND_URL=https://proyecto-el-arca.vercel.app

# ─── Credenciales de Gmail para Nodemailer ────────────
# Usa una "Contraseña de aplicación" de Google (no tu contraseña normal)
EMAIL_USER=archivo.elarca@gmail.com
EMAIL_PASS=tu-contrasena-de-aplicacion

# ─── Correo receptor de los archivos ──────────────────
EMAIL_RECEIVER=archivo.elarca@gmail.com
